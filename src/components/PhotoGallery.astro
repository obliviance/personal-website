---
import { Image } from 'astro:assets';
import 'photoswipe/style.css';

// Grab all images from the folder automatically
const images = await import.meta.glob<{ default: ImageMetadata }>('/src/assets/album/*.{jpeg,jpg,png,gif}');
const imagePaths = Object.values(images);
---

<div id="gallery" class="photo-gallery pswp-gallery">
  {imagePaths.map(async (image) => {
    const img = (await image()).default;
    return (
      <a 
        href={img.src} 
        data-pswp-width={img.width} 
        data-pswp-height={img.height} 
        target="_blank"
        class="gallery-item"
      >
        <Image 
          src={img} 
          alt="Gallery Image" 
          width={400}
        />
      </a>
    )
  })}
</div>

<style>
  .photo-gallery {
    display: grid;
    grid-template-rows: repeat(2, 280px);
    grid-auto-columns: minmax(280px, auto);
    grid-auto-flow: column;
    gap: 8px;
    padding: 16px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
  }

  .photo-gallery::-webkit-scrollbar {
    background-color: var(--color-border);
  }

  .photo-gallery::-webkit-scrollbar-thumb {
    background-color: var(--color-accent);
    border-radius: 4px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background-color: var(--color-border);
    transition: all 0.3s ease;
    display: block;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.05);
  }

  .gallery-item::before {
    display: none;
  }

  @media (max-width: 768px) {
    .photo-gallery {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      grid-auto-rows: 150px;
      gap: 4px;
      padding: 8px;
    }
  }

  @media (max-width: 480px) {
    .photo-gallery {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      grid-auto-rows: 100px;
      gap: 4px;
      padding: 4px;
    }
  }
</style>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  // Initialize PhotoSwipe
  const lightbox = new PhotoSwipeLightbox({
    gallery: '#gallery',
    children: 'a',
    pswpModule: () => import('photoswipe')
  });
  
  lightbox.init();
</script>