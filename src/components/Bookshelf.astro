---
import Book from './Book.astro';

interface BookItem {
  id: string;
  hidden: boolean;
  title: string;
  author?: string;
  url: string;
  pageCount?: number;
  description?: string;
}

interface Props {
  books: BookItem[];
}

const { books } = Astro.props;

// Calculate total page count for proportional sizing
const totalPageCount = books.reduce((sum, book) => sum + (book.pageCount || 500), 0);
const maxShelfWidth = 400; // pixels - adjust as needed
---

<style>
  .bookshelf-container {
    margin: 2rem 0;
  }

  .bookshelf {
    display: flex;
    gap: 0;
    align-items: flex-end; /* Keeps books grounded on the bottom */
    min-height: 350px;
    padding: 0 1rem 12px 1rem; /* Added bottom padding for the shelf thickness */
    border-radius: var(--global-radius);
    overflow-x: auto;
    scroll-behavior: smooth;
    position: relative;
    
    /* The Back Wall (Interior of the shelf) */
    background: linear-gradient(180deg, 
      rgba(0, 0, 0, 0.25) 0%, 
      rgba(0, 0, 0, 0.05) 40%, 
      rgba(0, 0, 0, 0.1) 100%);
    box-shadow: inset 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  /* THE SHELF PLANK (The "Floor") */
  .bookshelf::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 12px; /* Thickness of the wood */
    background: #3d2b1f; /* A dark wood color */
    
    /* Wood Grain & Lighting effect on the plank edge */
    background-image: linear-gradient(
      to bottom, 
      rgba(255, 255, 255, 0.15) 0%, 
      rgba(0, 0, 0, 0.2) 100%
    );
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 2;
  }

  /* THE SHELF TOP SURFACE (Depth) */
  .bookshelf::before {
    content: '';
    position: absolute;
    bottom: 12px; /* Sits right on top of the plank */
    left: 0;
    right: 0;
    height: 40px; /* The depth of the surface books sit on */
    background: rgba(0, 0, 0, 0.15); /* Shadow cast by the books on the floor */
    transform: perspective(100px) rotateX(20deg);
    transform-origin: bottom;
    pointer-events: none;
  }

  .book-slot {
    flex: 0 0 calc(var(--bookWidth) * 1px);
    height: auto;
    z-index: 3; /* Ensure books sit on top of the shelf depth */
  }

  @media (max-width: 700px) {
    .bookshelf {
      min-height: 250px;
    }
  }
</style>

<div class="bookshelf-container">
  <div class="bookshelf">
    {
      books.map((book) => (
        <div 
            class="book-slot"
            style={`--bookWidth: ${(book.pageCount || 500) / totalPageCount * maxShelfWidth};`}
        >
          <Book
            title={book.title}
            author={book.author}
            url={book.url}
            pageCount={book.pageCount}
            description={book.description}
          />
        </div>
      ))
    }
  </div>
</div>
