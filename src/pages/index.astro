---
import BaseLayout from '../layouts/BaseLayout.astro';

import Bookshelf from '../components/Bookshelf.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import Posts from '../components/Posts.astro';

/* Extracts the experience data from the json file in src/assets */
import experienceData from '../assets/awwab-mahdi_20260303_1734.json';

const pageTitle = "Home";
---
<BaseLayout pageTitle={pageTitle}>

	<style>
		section {
			padding: 10% 0 10% 0;
			margin: 5% 0 5% 0;
		}
		#icon-container {
			display: flex;
			gap: 2rem;
			align-items: center;
		}
		#about-content {
			display: flex;
			gap: 4rem;
			align-items: flex-start;
		}
		#hero {
			flex: 1;
		}
		#hike-image {
			width: 50%;
			object-fit: cover;
			border-radius: var(--global-radius);
			transform: rotate(3deg);
		}
		#contact {
			border: var(--global-border);
			padding: 5% 10% 10% 10%;
			width: fit-content;
			margin: 0 auto;
			margin-bottom: 10%;
			border-radius: calc(var(--global-radius) * 2);
		}

		/* Mobile Responsiveness */
		@media (max-width: 700px) {
			section {
				padding: 8% 0 8% 0;
				margin: 3% 0 3% 0;
			}
			#icon-container {
				gap: 1.5rem;
			}
			#about-content {
				flex-direction: column;
				gap: 2rem;
				align-items: stretch;
			}
			#hero {
				flex: none;
			}
			#hike-image {
				width: 45%;
			}
		}

		@media (max-width: 480px) {
			section {
				padding: 6% 0 6% 0;
				margin: 2% 0 2% 0;
			}
			h1 {
				font-size: 2rem;
			}
			h3 {
				font-size: 1.5rem;
			}
			p li ul {
				font-size: 1.2rem;
			}
			#icon-container {
				margin-top: 5%;
				gap: 1rem;
			}
			#contact {
				padding: 8% 8% 8% 8%;
			}
			Footer {
				font-size: 0.1rem;
			}
		}
	</style>

	<section id="about">
		<div id="about-content">
			<div id="hero">
				<h3>Hello there!</h3>
				<h1>I'm Awwab Mahdi.</h1>
				<p>Growing software developer and researcher, based in Ottawa, Canada 🍁. </p>
				<p>If I'm not reading, you can catch me hiking, baking banana bread, or exploring new technologies.</p>
				<p>Feel free to check out my bookshelf, explore my projects, or get in touch with me through my contact information. Thanks for visiting!</p>
				<div id="icon-container">
					<a href="http://www.linkedin.com/in/AwwabM" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="1.5em" height="1.5em" viewBox="0 0 24 24"><circle cx="4" cy="4" r="2" fill="currentColor" fill-opacity="0"><animate fill="freeze" attributeName="fill-opacity" dur="0.15s" values="0;1"/></circle><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="4"><path stroke-dasharray="12" stroke-dashoffset="12" d="M4 10v10"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.15s" dur="0.2s" values="12;0"/></path><path stroke-dasharray="12" stroke-dashoffset="12" d="M10 10v10"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.45s" dur="0.2s" values="12;0"/></path><path stroke-dasharray="24" stroke-dashoffset="24" d="M10 15c0 -2.76 2.24 -5 5 -5c2.76 0 5 2.24 5 5v5"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.65s" dur="0.2s" values="24;0"/></path></g></svg>
					</a>
					<a href="http://github.com/obliviance" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="1.5em" height="1.5em" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path stroke-dasharray="32" stroke-dashoffset="32" d="M12 4c1.67 0 2.61 0.4 3 0.5c0.53 -0.43 1.94 -1.5 3.5 -1.5c0.34 1 0.29 2.22 0 3c0.75 1 1 2 1 3.5c0 2.19 -0.48 3.58 -1.5 4.5c-1.02 0.92 -2.11 1.37 -3.5 1.5c0.65 0.54 0.5 1.87 0.5 2.5c0 0.73 0 3 0 3M12 4c-1.67 0 -2.61 0.4 -3 0.5c-0.53 -0.43 -1.94 -1.5 -3.5 -1.5c-0.34 1 -0.29 2.22 0 3c-0.75 1 -1 2 -1 3.5c0 2.19 0.48 3.58 1.5 4.5c1.02 0.92 2.11 1.37 3.5 1.5c-0.65 0.54 -0.5 1.87 -0.5 2.5c0 0.73 0 3 0 3"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.7s" values="32;0"/></path><path stroke-dasharray="10" stroke-dashoffset="10" d="M9 19c-1.41 0 -2.84 -0.56 -3.69 -1.19c-0.84 -0.63 -1.09 -1.66 -2.31 -2.31"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.8s" dur="0.2s" values="10;0"/></path></g></svg>
					</a>
				</div>
			</div>
			<img id="hike-image" src="src/assets/hike.jpg">
		</div>
		<Bookshelf books={experienceData.sections.books.items} />
	</section>

	<section id="experience">
		<h1>Experience</h1>
		<Skills skills={experienceData.sections.skills.items} />
		<Experience	experiences={experienceData.sections.experience.items} />
		<Education education={experienceData.sections.education.items[0]} />
		<p>You can also view my full <a
				href="/awwab-mahdi-resume.pdf"
				target="_blank"
				rel="noopener noreferrer">Resume↗</a
			> here.</p>
	</section>

	<section id="portfolio">
		<h1>Portfolio</h1>
		<Projects projects={experienceData.sections.projects.items} />
		<Posts />
	</section>

	<section id="contact">
		<h1 style="text-align: center;">Contact</h1>
		<p style="text-align: center;">Get in touch.</p>
		<div style="align-items: center; display: flex; gap: 2rem; justify-content: center;">
			<a href="mailto:awwab.mahdi@gmail.com">Email</a>
			<a href="http://www.linkedin.com/in/AwwabM" target="_blank" rel="noopener noreferrer">LinkedIn</a>
			<a href="http://github.com/obliviance" target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
	</section>


</BaseLayout>